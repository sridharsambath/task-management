# ── Local development ──────────────────────────────────────────────────────────
# URL of the Laravel API backend (running locally via Docker or artisan serve)
NUXT_PUBLIC_API_BASE=http://localhost:8000

# Anthropic API key for the Claude AI "suggest description" feature.
# Get yours at: https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Netlify (set these as Environment Variables in the Netlify dashboard) ──────
# Replace with the actual URL of your deployed Laravel backend.
# NUXT_PUBLIC_API_BASE=https://your-laravel-backend.example.com
#
# Your Anthropic API key (same value, set securely in Netlify env vars).
# ANTHROPIC_API_KEY=sk-ant-...
